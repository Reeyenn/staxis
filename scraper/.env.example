# Choice Advantage credentials
CA_USERNAME=bcobbs.txa32
CA_PASSWORD=your_password_here

# Firebase Admin (from Firebase Console → Project Settings → Service Accounts)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# HotelOps property config
HOTELOPS_USER_ID=the_firebase_uid_of_the_hotel_owner
HOTELOPS_PROPERTY_ID=the_firestore_property_doc_id

# Scraper config
SCRAPE_INTERVAL_MINUTES=15
OPERATIONAL_HOURS_START=6
OPERATIONAL_HOURS_END=22
# Hotel's local timezone (Railway runs UTC — this fixes operational hours + date bucketing)
TIMEZONE=America/Chicago
