# ═══════════════════════════════════════════════════════════════════════════
# Staxis scraper env vars — copy to .env and fill in.
# Schema lives in scraper/env.js; this file is hand-mirrored from it.
#
# Legacy fallbacks (SUPABASE_URL, TWILIO_PHONE_NUMBER, MANAGER_PHONE) are
# still accepted by the schema during the migration window — do NOT set
# them in new deploys.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Required ──────────────────────────────────────────────────────────
# Supabase project (NEXT_PUBLIC_ prefix matches the main app — scraper
# is a server-only process, the prefix is a naming-consistency choice).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Choice Advantage credentials ──────────────────────────────────────
# Required when HOTELOPS_PROPERTY_ID is set and the scraper isn't loading
# credentials from the scraper_credentials DB table.
CA_USERNAME=bcobbs.txa32
CA_PASSWORD=your_password_here

# ─── Property scope ────────────────────────────────────────────────────
# UUID of the properties row this scraper deploy belongs to. When unset,
# the scraper loads its property list from scraper_credentials via
# loadActiveProperties().
HOTELOPS_PROPERTY_ID=

# ─── Operational tuning ────────────────────────────────────────────────
# Hotel's local timezone — Railway runs UTC. Affects date bucketing and
# the morning/evening pull schedule.
TIMEZONE=America/Chicago

# How often the tick loop wakes up to check "is it 6am or 7pm yet?".
# Default 5 minutes — frequent enough to never miss an hour boundary.
TICK_MINUTES=5

# CSV sanity check: minimum rooms parsed per CSV pull (default 60).
# Below this triggers a scraper-health alert via SMS.
MIN_EXPECTED_ROOMS=60

# Dev-only: run a single CSV scrape immediately on startup instead of
# waiting for the next 6am trigger.
CSV_TEST_ON_STARTUP=false

# Run Playwright in headed mode (visible browser) for local debugging.
# Always false on Railway.
HEADED=false

# Multi-scraper deploys tag rows with this instance ID so the app can
# attribute "which scraper produced this status row". Default 'default'.
SCRAPER_INSTANCE_ID=default

# ─── Cron / shared secret ──────────────────────────────────────────────
# Must match CRON_SECRET on Vercel and in GitHub Actions secrets.
CRON_SECRET=

# ─── Alerting (optional) ───────────────────────────────────────────────
# Scraper sends SMS via Twilio when it can't recover from a scrape
# failure. OPS_ALERT_PHONE is the recipient; phone format E.164.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
OPS_ALERT_PHONE=

# ─── Vercel watchdog ───────────────────────────────────────────────────
# Override for the doctor URL the watchdog pings every 5 min. Defaults
# to https://getstaxis.com/api/admin/doctor.
VERCEL_DOCTOR_URL=
