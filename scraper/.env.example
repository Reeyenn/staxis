# Choice Advantage credentials
CA_USERNAME=bcobbs.txa32
CA_PASSWORD=your_password_here

# Supabase (server-only — never expose the service_role key to browsers)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# HotelOps property config
HOTELOPS_USER_ID=the_data_user_id_uuid_of_the_hotel_owner
HOTELOPS_PROPERTY_ID=the_supabase_property_row_id_uuid

# Scraper config
SCRAPE_INTERVAL_MINUTES=15
OPERATIONAL_HOURS_START=6
OPERATIONAL_HOURS_END=22
# Hotel's local timezone (Railway runs UTC — this fixes operational hours + date bucketing)
TIMEZONE=America/Chicago

# Cross-platform failsafe: Railway watchdog pings Vercel's /api/admin/doctor
# every 5 min. Must match CRON_SECRET on Vercel and in GitHub Actions secrets.
CRON_SECRET=
