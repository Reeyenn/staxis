# cua-service environment variables — Fly.io worker (staxis-cua app)
#
# Source of truth: cua-service/src/env.ts (Zod schema, parsed at module load).
# When you add a var to env.ts, also add it here so deploy operators see the
# full contract. Both files are checked in.
#
# To set these on Fly: `fly secrets set KEY=value -a staxis-cua` (then `fly deploy`).
# To run locally: copy this file to cua-service/.env (or symlink the parent
# .env.local) and fill in real values.

# ─── Supabase (REQUIRED) ─────────────────────────────────────────
# Worker uses the service-role key to read onboarding_jobs + write
# pms_recipes / pms_mapping rows past RLS.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SUPABASE_SERVICE_ROLE_KEY

# ─── Anthropic (REQUIRED) ────────────────────────────────────────
# Claude vision drives the browser-tool mapper. Must start with `sk-ant-`.
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_ANTHROPIC_API_KEY

# ─── Sentry (optional — SDK no-ops if unset) ─────────────────────
SENTRY_DSN=

# ─── Worker tuning (defaults are sensible; override only when needed) ─
# Per-job wall-clock timeout. 900_000 ms = 15 min.
JOB_TIMEOUT_MS=900000
# Poll interval for new jobs from onboarding_jobs.
POLL_INTERVAL_MS=5000
# Choice Advantage CSV-pull timeout. 180_000 ms = 3 min.
PULL_TIMEOUT_MS=180000
WORKER_ID_PREFIX=cua
# Hard cost ceiling per job in micro-USD (5_000_000 = $5).
CUA_JOB_COST_CAP_MICROS=5000000

# ─── Recipe signing (Plan v2 F-AI-2) ────────────────────────────
# HMAC keys used to sign pms_recipes.recipe rows. Min 32 bytes each.
# RECIPE_SIGNING_KEY is the active key; *_PREVIOUS is accepted during
# a rotation grace window. Unset PREVIOUS after doctor reports
# `recipes_all_signed`=100%.
RECIPE_SIGNING_KEY=
RECIPE_SIGNING_KEY_PREVIOUS=
# 'warn' (default) logs mismatches but proceeds; 'enforce' refuses.
RECIPE_SIGNING_ENFORCE=warn

# ─── CUA action policy (Plan v2 F-AI-7) ─────────────────────────
# 'warn' — logs refused phase-violating actions but lets them through.
# 'enforce' — refuses, agent retries.
CUA_POLICY_ENFORCE=warn

# ─── Screenshot minimization (Plan v2 F-AI-10) ──────────────────
# 'false' (default): Claude relies on read_page + get_page_text.
# 'true': auto-capture screenshots on navigate + hover (legacy behavior).
CUA_AUTO_SCREENSHOT=false

# ─── DNS rebinding preflight (Plan v2 F-AI-5) ───────────────────
# 'true' refuses navigation to hosts that resolve to private IPs.
# Adds dns.lookup latency; off by default during rollout.
CUA_DNS_PREFLIGHT=false
CUA_DNS_PREFLIGHT_TIMEOUT_MS=2000

# ─── Platform auto-injected (DO NOT set manually) ───────────────
# These are set by Fly at boot. Listed here so the schema is complete.
# NODE_ENV=production
# FLY_APP_NAME=staxis-cua
# FLY_MACHINE_ID=
# FLY_REGION=
# HOSTNAME=
