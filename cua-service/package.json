{
  "name": "@staxis/cua-service",
  "version": "0.1.0",
  "private": true,
  "description": "Computer Use Agent worker that maps and pulls data from any PMS. Polls onboarding_jobs in Supabase, runs Claude vision when learning a new PMS, runs Playwright when replaying a known recipe.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p . && cp -R src/browser-utils dist/",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit -p ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@sentry/node": "^10.53.1",
    "@supabase/supabase-js": "^2.47.0",
    "dotenv": "^17.4.2",
    "playwright": "1.59.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
