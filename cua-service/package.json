{
  "name": "@staxis/cua-service",
  "version": "0.1.0",
  "private": true,
  "description": "Computer Use Agent worker that maps and pulls data from any PMS. Polls onboarding_jobs in Supabase, runs Claude vision when learning a new PMS, runs Playwright when replaying a known recipe.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p .",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit -p ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.0",
    "@sentry/node": "^8.50.0",
    "@supabase/supabase-js": "^2.47.0",
    "dotenv": "^16.4.5",
    "playwright": "^1.49.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
