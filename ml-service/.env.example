# ml-service environment variables — Railway-hosted FastAPI service
#
# Source of truth: ml-service/src/config.py (Pydantic Settings).
# `case_sensitive = False`, so SUPABASE_URL and supabase_url both work; the
# UPPERCASE form is the convention here. Validated at boot by the lifespan
# handler in src/main.py — missing required values crash the container with
# a clear log instead of serving 500s on first /predict.
#
# To set on Railway: dashboard → Variables (or `railway variables --set
# KEY=value`). To run locally: copy this file to ml-service/.env and fill
# in real values.

# ─── Supabase (REQUIRED) ─────────────────────────────────────────
# Service-role key bypasses RLS — needed for cron-driven training
# and the auto-rollback path that reads prediction_log.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SUPABASE_SERVICE_ROLE_KEY

# ─── ML bearer secret (REQUIRED, ≥8 chars at boot; ≥32 in prod) ─
# All /train and /predict endpoints require Bearer <ML_SERVICE_SECRET>.
# The doctor's `ml_service_secret_strength` check enforces the 32-char
# prod floor as a hard fail. See RUNBOOKS.md > ML_SERVICE_SECRET rotation.
ML_SERVICE_SECRET=REPLACE_WITH_32PLUS_BYTE_SECRET

# ─── Direct Postgres (optional fallback) ────────────────────────
# Used by advisory locks + auto-rollback path (psycopg2 needs the raw
# Postgres URL, NOT the PostgREST gateway at supabase_url). If unset,
# the config falls back to DATABASE_URL or SUPABASE_DB_URL.
# DATABASE_URL=postgres://user:pass@host:5432/postgres

# ─── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── API-boundary safety limits (Plan v2 F-AI-4) ────────────────
# DoS protection — see ml-service/src/main.py middleware. Tested
# by test_main_hardening.py: an 80 KiB body MUST be rejected, so do
# NOT raise ml_max_body_bytes above 81920 without updating that test.
ML_MAX_ROWS_CAP=200000
ML_MAX_BODY_BYTES=65536

# ─── Training thresholds (defaults are well-tuned; rarely override) ─
# See config.py for full context per field.
# TRAINING_ROW_COUNT_MIN=200
# TRAINING_ROW_COUNT_ACTIVATION=500
# VALIDATION_MAE_RATIO_THRESHOLD=0.10
# VALIDATION_MAE_FLOOR=1.0
# BASELINE_BEAT_PCT_THRESHOLD=0.20
# CONSECUTIVE_PASSING_RUNS_REQUIRED=2
# MIN_HOURS_BETWEEN_PASSING_RUNS=24

# ─── Model architecture (rarely override) ───────────────────────
# SHIFT_CAP_MINUTES=420
# TARGET_COMPLETION_PROBABILITY=0.95
# MONTE_CARLO_DRAWS=1000

# ─── Auto-rollback (Phase 7 v2) ─────────────────────────────────
# Default true: cron logs "would-have-fired" without touching model_runs.
# Flip to false ONLY after 30 days of clean dry-run audit. Hot-reloads
# without a redeploy (get_settings is re-instantiated per request).
AUTO_ROLLBACK_DRY_RUN=true
# AUTO_ROLLBACK_FDR_ALPHA=0.05
# AUTO_ROLLBACK_MIN_PAIRED_DAYS=21
# AUTO_ROLLBACK_COOLDOWN_DAYS=14
# AUTO_ROLLBACK_ACTUALS_CORRECTION_DAYS=3
# AUTO_ROLLBACK_WINDOW_DAYS=14
# AUTO_ROLLBACK_PVALUE_THRESHOLD=0.05
# DISAGREEMENT_THRESHOLD_FALLBACK=0.30
# DISAGREEMENT_ZSCORE_THRESHOLD=2.0

# ─── Inventory rate model (rarely override) ─────────────────────
# INVENTORY_MIN_EVENTS_PER_ITEM=3
# INVENTORY_XGBOOST_ACTIVATION_EVENTS=100
# INVENTORY_GRADUATION_MIN_EVENTS=30
# INVENTORY_GRADUATION_MAE_RATIO=0.10
# INVENTORY_GRADUATION_CONSECUTIVE_PASSES=5
