    "/train/demand-priors": {
      "post": {
        "description": "Recompute demand_priors from network data.\n\nReads cleaning_minutes_per_day_view for the last 90 days, normalizes\neach property's daily total to per-room (so hotels of different sizes\nare comparable), takes per-property median, then per-cohort median.\n\nCohort key construction matches inventory_priors:\n  ['global', '<brand-region-size_tier>'] when all 3 fields populated.\n\n'global' cohort needs 5+ hotels before overriding the\nindustry-benchmark seed in demand_priors. Specific cohorts always\nupsert (they only exist when there's real cohort data).\n\nIdempotent \u2014 each run replaces every cohort row with source='cohort-aggregate'.\nIndustry-benchmark seeds (source='industry-benchmark') are NOT touched.\n\nRequires bearer token authentication.",
        "operationId": "train_demand_priors_endpoint_train_demand_priors_post",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AggregatePriorsResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "summary": "Aggregate cross-hotel demand cohort priors (Phase M3)",
        "tags": [
          "training"
        ]
      }
    },
