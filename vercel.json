    },
    {
      "path": "/api/cron/sweep-mfa-verified-sessions",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/webhook-dedup-purge",
      "schedule": "15 4 * * *"
    },
    {
      "path": "/api/cron/pms-auth-codes-purge",
      "schedule": "45 4 * * *"
    },
    {
      "path": "/api/cron/vercel-watchdog",
      "schedule": "*/5 * * * *"
    }
  ]
}
