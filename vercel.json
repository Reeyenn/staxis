{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/expire-help-requests",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/agent-sweep-reservations",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/process-agent-schedules",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/agent-archive-stale-conversations",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/claude-sessions-purge",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/cron/agent-summarize-long-conversations",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/agent-consolidate-memory",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/agent-heal-counters",
