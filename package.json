{
  "name": "hotelops-ai",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src scraper --max-warnings 0 && node scripts/check-env-access.mjs",
    "seed": "node scripts/seed-supabase.js",
    "seed:reset": "node scripts/seed-supabase.js --reset",
    "db:types": "npx supabase gen types typescript --project-id \"$SUPABASE_PROJECT_REF\" | sed '/<claude-code-hint/d' > src/types/database.types.ts",
    "agent:evals": "tsx scripts/run-agent-evals.ts",
    "agent:summarizer-evals": "tsx scripts/run-summarizer-evals.ts",
    "agent:invariant-evals": "tsx scripts/run-agent-invariant-evals.ts",
    "test": "npm run test:pii-logs && node --test scraper/__tests__/*.test.js && NEXT_PUBLIC_SUPABASE_URL=https://placeholder.supabase.co SUPABASE_SERVICE_ROLE_KEY=placeholder-service-role-key-min-20-chars NEXT_PUBLIC_SUPABASE_ANON_KEY=placeholder-anon-key-min-20-chars CRON_SECRET=placeholder-cron-secret-min-16 npx tsx --test src/lib/__tests__/*.test.ts",
    "test:scraper": "node --test scraper/__tests__/*.test.js",
    "test:pii-logs": "bash scripts/check-no-pii-logs.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@elevenlabs/client": "^1.7.0",
    "@picovoice/porcupine-web": "^4.0.0",
    "@picovoice/web-voice-processor": "^4.0.10",
    "@sentry/nextjs": "^10.51.0",
    "@supabase/supabase-js": "^2.47.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.14.0",
    "next": "^16.2.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "stripe": "^22.1.1",
    "tailwind-merge": "^3.3.0",
    "twilio": "^6.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "jsdom": "^29.1.1",
    "pg": "^8.20.0",
    "postcss": "^8",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
