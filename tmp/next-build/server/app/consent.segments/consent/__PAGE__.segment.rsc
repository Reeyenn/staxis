5:["$","div",null,{"className":"section","children":[["$","p",null,{"className":"section-title","children":"Message Details"}],["$","div",null,{"className":"field-row","children":[["$","span",null,{"className":"field-label","children":"Sender"}],["$","span",null,{"className":"field-value","children":"Staxis (+1 855-514-1450)"}]]}],["$","div",null,{"className":"field-row","children":[["$","span",null,{"className":"field-label","children":"Recipients"}],["$","span",null,{"className":"field-value","children":"Hotel employees only (no consumers)"}]]}],["$","div",null,{"className":"field-row","children":[["$","span",null,{"className":"field-label","children":"Frequency"}],["$","span",null,{"className":"field-value","children":"Once per day, nightly"}]]}],["$","div",null,{"className":"field-row","children":[["$","span",null,{"className":"field-label","children":"Purpose"}],["$","span",null,{"className":"field-value","children":"Internal workforce scheduling"}]]}],["$","div",null,{"className":"field-row","children":[["$","span",null,{"className":"field-label","children":"Opt-out method"}],["$","span",null,{"className":"field-value","children":"Reply STOP to any message"}]]}],["$","div",null,{"className":"example-box","children":[["$","p",null,{"className":"example-label","children":"Example Message"}],["$","p",null,{"children":"Staxis: Can you work tomorrow (Fri Apr 4)? Reply YES or NO. Reply STOP to opt out."}]]}]]}]
6:["$","div",null,{"className":"section","children":[["$","p",null,{"className":"section-title","children":"What These Messages Are Not"}],["$","div",null,{"className":"section-body","children":["$","p",null,{"children":"These messages are not marketing, promotional, or consumer-facing communications. They are strictly internal employee scheduling notifications sent to hotel staff who have been informed of and agreed to receive them as part of their employment."}]}]]}]
7:["$","footer",null,{"children":[["$","div",null,{"style":{"marginBottom":"6px"},"children":"Staxis — operated by Reeyen Patel (sole proprietor)"}],["$","div",null,{"style":{"marginBottom":"6px"},"children":"2215 Rio Grande St, Austin, TX 78705, United States"}],["$","div",null,{"children":["For questions contact ",["$","a",null,{"href":"mailto:rp@reeyenpatel.com","style":{"color":"#6b7280"},"children":"rp@reeyenpatel.com"}]]}]]}]
