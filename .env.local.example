# ─────────────────────────────────────────────────────────────────────
# Supabase
# https://app.supabase.com → your project → Project Settings → API
# service_role key is server-only — never ship it to the browser.
# ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Used by tools that mint server-side Supabase clients without going
# through the auth helper (a few admin scripts). Same value as
# NEXT_PUBLIC_SUPABASE_URL.
SUPABASE_URL=https://xxx.supabase.co

# ─────────────────────────────────────────────────────────────────────
# App origin
# Canonical public origin. Used for Stripe checkout redirects and any
# server-side absolute URL construction. Prod sets this on Vercel
# (https://getstaxis.com). Locally point at your dev server.
# ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Fallbacks read by /api/sms-reply if APP_URL isn't set:
NEXT_PUBLIC_BASE_URL=
NEXT_PUBLIC_SITE_URL=

# ─────────────────────────────────────────────────────────────────────
# Twilio SMS
# Console → Account → API keys. TWILIO_FROM_NUMBER is the sending
# phone number (e164). TWILIO_PHONE_NUMBER is accepted as a fallback.
# ─────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_PHONE_NUMBER=
MANAGER_PHONE=
OPS_ALERT_PHONE=

# ─────────────────────────────────────────────────────────────────────
# Cron / webhook auth
# Shared secret used by Vercel cron, GitHub Actions, and Railway to
# call into the app. Must match across all three places.
# ─────────────────────────────────────────────────────────────────────
CRON_SECRET=

# ─────────────────────────────────────────────────────────────────────
# Default property
# Property id the scraper + crons operate against when no property is
# passed explicitly. Used by the housekeeping seed flow.
# ─────────────────────────────────────────────────────────────────────
STAXIS_DEFAULT_PROPERTY_ID=

# ─────────────────────────────────────────────────────────────────────
# Anthropic — agent + extraction calls
# https://console.anthropic.com → API keys
# ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────────────
# Stripe — checkout + webhook
# Dashboard → Developers → API keys / Webhooks. Use test keys in dev.
# STRIPE_PRICE_ID is the subscription product price (price_…).
# ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# ─────────────────────────────────────────────────────────────────────
# Sentry — error reporting
# https://sentry.io → project settings → Client Keys (DSN).
# NEXT_PUBLIC_SENTRY_DSN is the browser SDK; SENTRY_DSN is server.
# Same DSN value is fine; the split lets us send a different one to
# the client if we ever want to.
# ─────────────────────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN: only needed in CI / Vercel production builds, NOT
# for local dev. When present, the Next build uploads source maps to
# Sentry so prod stack traces resolve to real file/line numbers
# instead of minified chunk paths. See docs/sentry-sourcemaps-
# activation.md for the 4-step setup.
SENTRY_AUTH_TOKEN=

# ─────────────────────────────────────────────────────────────────────
# ML service (Python, Fly.io)
# ML_SERVICE_URL = single shard (legacy). ML_SERVICE_URLS = comma-
# separated list for multi-shard inference. ML_SERVICE_SECRET is the
# shared bearer token the web app sends with every call.
# ─────────────────────────────────────────────────────────────────────
ML_SERVICE_URL=
ML_SERVICE_URLS=
ML_SERVICE_SECRET=

# ─────────────────────────────────────────────────────────────────────
# Railway — scraper service
# Used by /api/cron/scraper-health to ping the scraper. The Railway
# URL of the Choice Advantage / OPERA / etc. scraper deployment.
# ─────────────────────────────────────────────────────────────────────
RAILWAY_SCRAPER_URL=

# ─────────────────────────────────────────────────────────────────────
# GitHub — webhooks + Codex review trigger
# Personal access token with `repo` scope. Webhook secret is the
# shared signing secret configured on the repo webhook.
# ─────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────────
# Vercel — for /api/admin/doctor and self-deploy checks
# Personal API token + the staxis project + team IDs. Only needed
# locally if you run the doctor route against prod.
# ─────────────────────────────────────────────────────────────────────
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
# Override for doctor to point at a non-default deploy (rare).
VERCEL_DOCTOR_URL=

# ─────────────────────────────────────────────────────────────────────
# Fly.io — for /api/admin/codex (Codex review trigger)
# API token + app name of the Codex worker.
# ─────────────────────────────────────────────────────────────────────
FLY_API_TOKEN=
FLY_APP_NAME=

# ─────────────────────────────────────────────────────────────────────
# reCAPTCHA v3 (optional)
# ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# ─────────────────────────────────────────────────────────────────────
# Timezone — used by the doctor route to display schedules. Default
# America/Chicago (Reeyen's ops timezone). Set explicitly if running
# against a different property's local tz.
# ─────────────────────────────────────────────────────────────────────
TIMEZONE=America/Chicago
