# Supabase Configuration
# 1. Go to https://app.supabase.com → create or open your project
# 2. Project Settings → API: copy Project URL, anon/public key, and service_role key
# 3. The service_role key is server-only — never ship it to the browser

# Client-safe (exposed via NEXT_PUBLIC_*)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-only — used by admin API routes, scraper, crons
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Property id Maria logs into by default (used by scraper + crons)
STAXIS_DEFAULT_PROPERTY_ID=

# Twilio SMS (existing — unchanged)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
MANAGER_PHONE=

# Cron/webhook auth secret — must match across Vercel, Railway, and GitHub Actions
CRON_SECRET=

# reCAPTCHA v3 site key (optional; App Check parity)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
