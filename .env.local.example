# ═══════════════════════════════════════════════════════════════════════════
# Staxis main-app env vars — copy to .env.local and fill in.
# Schema lives in src/lib/env.ts; this file is hand-mirrored from it.
#
# Required vars (boot fails if missing) are at the top. Everything below is
# optional; missing ones gracefully disable the feature.
#
# Legacy fallbacks (TWILIO_PHONE_NUMBER, MANAGER_PHONE, NEXT_PUBLIC_SITE_URL,
# NEXT_PUBLIC_BASE_URL, SUPABASE_URL, ML_SERVICE_URL) are STILL ACCEPTED by
# the schema during the migration window (see env-vars-audit Phase 7) — do
# NOT set them in new deploys.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Required ──────────────────────────────────────────────────────────
# Supabase project — https://app.supabase.com → Project Settings → API.
# service_role key is server-only — never ship it to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── App origin ────────────────────────────────────────────────────────
# Canonical public origin. Used for Stripe checkout redirects, SMS link
# templates, and any server-side absolute URL construction. Defaults to
# https://getstaxis.com when unset.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Cron / internal secrets ───────────────────────────────────────────
# Shared bearer token. Vercel cron, GitHub Actions, and Railway all
# attach this on cross-service calls. requireCronSecret() fails closed
# in production if unset.
CRON_SECRET=

# Internal secret for the /api/local-worktrees/sync endpoint (Reeyen's
# local hook posts the worktree list). Distinct from CRON_SECRET so it
# can be rotated independently.
LOCAL_SYNC_SECRET=

# GitHub webhook signing secret — required if /api/github-webhook is wired
# up in the repo settings.
GITHUB_WEBHOOK_SECRET=

# ─── Anthropic / LLM ───────────────────────────────────────────────────
# Required for the agent layer (/api/agent/* + vision-extract). Format:
# sk-ant-api03-…
ANTHROPIC_API_KEY=

# LLM model override — comma-separated "<tier>=<snapshot>" pairs, e.g.
# "sonnet=claude-sonnet-4-6-20260427". Freezes the agent to a specific
# Anthropic snapshot. Used to roll back when a snapshot regresses evals.
MODEL_OVERRIDE=

# ─── Twilio SMS (optional — graceful disable when unset) ───────────────
# Console → Account → API keys. From-number must be E.164 (e.g.
# +18445971608). The SID/token pair is the "Live" auth, not the test one.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Twilio balance alert thresholds (USD). Doctor route warns below WARN
# and fails below FAIL. Defaults: WARN=10, FAIL=5.
TWILIO_BALANCE_WARN_USD=10
TWILIO_BALANCE_FAIL_USD=5

# ─── Stripe (optional — graceful disable when secret OR webhook missing)
# Dashboard → Developers → API keys / Webhooks. STRIPE_PRICE_ID is the
# subscription product price (price_…).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# ─── ElevenLabs (voice agent) ──────────────────────────────────────────
# Required for /api/agent/voice-session, /api/agent/speak,
# /api/agent/voice-brain. Webhook secret signs incoming brain webhooks.
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_VOICE_ID=
ELEVENLABS_WEBHOOK_SECRET=

# ─── Email (Resend) ────────────────────────────────────────────────────
# Required for all transactional email (signup invites, password resets,
# weekly digests). Format: re_…
RESEND_API_KEY=

# ─── Sentry — error reporting ──────────────────────────────────────────
# Same DSN value is fine for both server and client; split lets us send
# a different DSN to the browser later if needed.
# SENTRY_AUTH_TOKEN: only set in CI / Vercel production build env;
# enables sourcemap upload during `next build` so prod stack traces
# resolve to real file/line numbers.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Webhook secret for Sentry → /api/sentry-webhook (HMAC SHA256 of body).
SENTRY_WEBHOOK_SECRET=

# ─── Voice / wake-word ─────────────────────────────────────────────────
# Picovoice Porcupine access key for "Hey Staxis" wake word. When unset,
# the Settings toggle hides itself and the WakeWord component refuses to
# initialize. Docs: docs/wake-word-setup.md.
PICOVOICE_ACCESS_KEY=

# ─── reCAPTCHA v3 (optional) ───────────────────────────────────────────
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# ─── Ops alert phone ───────────────────────────────────────────────────
# E.164 phone receiving inventory alerts, scraper-health failures, and
# Sentry-critical SMS. Cron routes fall back to this when a property
# lacks its own alert_phone.
OPS_ALERT_PHONE=

# ─── ML service routing ────────────────────────────────────────────────
# Comma-separated URLs for multi-shard inference. Single shard is just
# one entry. ML_SERVICE_SECRET is the shared bearer the web app sends
# with every call.
ML_SERVICE_URLS=
ML_SERVICE_SECRET=

# ─── Admin / DevOps tokens ─────────────────────────────────────────────
# Personal access tokens used by /api/admin/* surfaces. GITHUB_TOKEN
# needs `repo` scope; FLY_API_TOKEN is for the Codex review trigger
# (see /api/admin/codex). VERCEL_* are for the /api/admin/doctor self-
# deploy check. RAILWAY_SCRAPER_URL is the public URL of the Choice
# Advantage / OPERA scraper deployment (used by scraper-health cron).
GITHUB_TOKEN=
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
VERCEL_DOCTOR_URL=
FLY_API_TOKEN=
FLY_APP_NAME=staxis-cua
RAILWAY_SCRAPER_URL=

# ─── Timezone ──────────────────────────────────────────────────────────
# Used by the doctor route for schedule display. Default America/Chicago
# (Reeyen's ops timezone).
TIMEZONE=America/Chicago

# ─── Test-only ─────────────────────────────────────────────────────────
# Property UUID used by /api/admin/doctor's smoke checks. Don't set in
# prod — leave empty so the smoke section is skipped.
SMOKE_PROPERTY_ID=
