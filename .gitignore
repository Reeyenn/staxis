# filesystem artifacts
.fuse_hidden*

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/
# Local-only Next.js build snapshot some script writes when restoring
# state. Pure cache; never want it tracked.
/.next-backup/
# Stray Next.js build output. An earlier build (or a colleague's machine)
# committed ~1k files under tmp/next-build/ — including a generated
# validator.ts that referenced every API route in the repo. When we
# deleted the legacy notify-housekeepers routes on 2026-04-30 the stale
# committed validator.ts kept importing them, and Vercel's build started
# failing with 'Cannot find module .../route.js' three times in a row.
# Hard-block the entire tmp/ tree so this category of stale-build-cache
# bug can't recur.
/tmp/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# 2026-05-22 monitoring/logging/secrets hardening — explicit defense in depth
# for the per-sub-unit .env files (scraper/, cua-service/, ml-service/). The
# root `.env*.local` rule above matches `.env.local` at any depth, but a
# stray `git add scraper/` would still pick up a literal `scraper/.env` file
# that doesn't have the `.local` suffix. Listing each unit explicitly keeps
# secrets out of git even when a contributor copies `.env.example` to
# `.env` without thinking.
scraper/.env
scraper/.env.local
scraper/.env.*
!scraper/.env.example
cua-service/.env
cua-service/.env.local
cua-service/.env.*
!cua-service/.env.example
ml-service/.env
ml-service/.env.local
ml-service/.env.*
!ml-service/.env.example

# vercel
.vercel

# supabase CLI temp marker — written every time `supabase` runs to
# track the latest CLI version. Pure cache; never want it tracked.
supabase/.temp/

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code
.claude/worktrees/
.claude/scheduled_tasks.lock
.claude/scheduled_tasks*.json
CLAUDE.md

# Local-only deploy helpers — these can contain API keys / secrets at any
# moment (we use them as throwaway one-shot deploy scripts via Finder
# double-click, since Cowork's computer-use blocks typing into Terminal).
# Never commit them — write a fresh one each session and let it stay
# untracked.
*.command
/.staxis-push-patches/
/.audit-fix-tmp/
/audit-fix/
