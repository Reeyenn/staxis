# filesystem artifacts
.fuse_hidden*

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/
# Stray Next.js build output. An earlier build (or a colleague's machine)
# committed ~1k files under tmp/next-build/ — including a generated
# validator.ts that referenced every API route in the repo. When we
# deleted the legacy notify-housekeepers routes on 2026-04-30 the stale
# committed validator.ts kept importing them, and Vercel's build started
# failing with 'Cannot find module .../route.js' three times in a row.
# Hard-block the entire tmp/ tree so this category of stale-build-cache
# bug can't recur.
/tmp/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code
.claude/worktrees/
CLAUDE.md
